/**
 * 帮我看看 - 全局样式
 */

/* ========== 基础样式 ========== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #262626;
  background-color: #F5F5F5;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

/* ========== 主题色 ========== */
.text-primary { color: #1677FF; }
.text-success { color: #52C41A; }
.text-warning { color: #FAAD14; }
.text-danger { color: #F5222D; }
.text-secondary { color: #595959; }
.text-placeholder { color: #8C8C8C; }
.text-white { color: #FFFFFF; }

.bg-primary { background-color: #1677FF; }
.bg-white { background-color: #FFFFFF; }
.bg-gray { background-color: #F5F5F5; }

/* ========== 布局 ========== */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-end { align-items: flex-end; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.flex-1 { flex: 1; }

/* ========== 间距 ========== */
.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mt-xl { margin-top: 32rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.mb-lg { margin-bottom: 24rpx; }
.ml-sm { margin-left: 8rpx; }
.ml-md { margin-left: 16rpx; }
.mr-sm { margin-right: 8rpx; }
.mr-md { margin-right: 16rpx; }
.p-md { padding: 16rpx; }
.p-lg { padding: 24rpx; }
.px-md { padding-left: 16rpx; padding-right: 16rpx; }
.py-md { padding-top: 16rpx; padding-bottom: 16rpx; }

/* ========== 卡片 ========== */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ========== 文字 ========== */
.text-bold { font-weight: 600; }
.text-center { text-align: center; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 16rpx 0;
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #8C8C8C;
}
.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

/* ========== 按钮辅助 ========== */
.btn-block {
  width: 100%;
  margin-top: 16rpx;
}

/* ========== 标签 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-primary { background-color: #E6F4FF; color: #1677FF; }
.tag-success { background-color: #F6FFED; color: #52C41A; }
.tag-warning { background-color: #FFFBE6; color: #FAAD14; }
.tag-danger { background-color: #FFF2F0; color: #F5222D; }

/* ========== 原生替代组件样式 ========== */

/* 原生按钮（替代 t-button） */
.native-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: #F5F5F5;
  color: #262626;
  border: none;
  line-height: 80rpx;
  box-sizing: border-box;
}
.native-btn.primary {
  background-color: #1677FF;
  color: #FFFFFF;
}
.native-btn.primary::after {
  border: none;
}
.native-btn.block {
  width: 100%;
}
.native-btn[disabled] {
  opacity: 0.5;
  background-color: #F5F5F5;
  color: #8C8C8C;
}

/* 原生加载（替代 t-loading） */
.native-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #8C8C8C;
  font-size: 26rpx;
}
.native-loading::before {
  content: '';
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #E6E6E6;
  border-top-color: #1677FF;
  border-radius: 50%;
  margin-bottom: 16rpx;
  animation: native-spin 0.8s linear infinite;
}
@keyframes native-spin {
  to { transform: rotate(360deg); }
}

/* 原生空状态（替代 t-empty） */
.native-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.native-empty::before {
  content: '📭';
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.native-empty-text {
  color: #8C8C8C;
  font-size: 26rpx;
}

/* 原生选项卡（替代 t-tabs） */
.native-tabs {
  display: flex;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
  padding: 0 24rpx;
}
.native-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #595959;
  position: relative;
}
.native-tab.active {
  color: #1677FF;
  font-weight: 600;
}
.native-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #1677FF;
  border-radius: 2rpx;
}

/* 原生输入框（替代 t-input） */
.native-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
  margin-top: 12rpx;
  box-sizing: border-box;
}
.native-input:focus {
  border-color: #1677FF;
}

/* 原生文本域（替代 t-textarea） */
.native-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx 24rpx;
  border: 1rpx solid #E6E6E6;
  border-radius: 12rpx;
  font-size: 28rpx;
  background-color: #FFFFFF;
  margin-top: 12rpx;
  box-sizing: border-box;
  line-height: 1.6;
}
.native-textarea:focus {
  border-color: #1677FF;
}

/* 原生单元格（替代 t-cell） */
.native-cell-group {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin: 16rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.native-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.native-cell:last-child {
  border-bottom: none;
}
.cell-title {
  font-size: 28rpx;
  color: #262626;
}
.cell-arrow {
  font-size: 24rpx;
  color: #C0C0C0;
}

/* loading 居中 */
.loading-center {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

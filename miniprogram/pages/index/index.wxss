.page-index { padding-bottom: 120rpx; }

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}
.search-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
}
.city-tag {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #1677FF;
  white-space: nowrap;
  padding: 8rpx 12rpx;
  background: #F0F7FF;
  border-radius: 8rpx;
}
.city-refresh {
  font-size: 20rpx;
  opacity: 0.7;
}

.filter-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}
.tab {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #595959;
  position: relative;
}
.tab.active {
  color: #1677FF;
  font-weight: 600;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1677FF;
  border-radius: 2rpx;
}

.post-card {
  cursor: pointer;
}
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}
.post-title { font-size: 32rpx; flex: 1; }
.reward-tag { display: flex; align-items: center; white-space: nowrap; margin-left: 16rpx; }
.reward-icon { font-size: 28rpx; }
.reward-amount { font-size: 28rpx; font-weight: 600; }
.post-desc { display: block; margin-bottom: 16rpx; font-size: 26rpx; line-height: 1.5; }
.post-footer { display: flex; justify-content: space-between; align-items: center; }
.post-meta { display: flex; align-items: center; font-size: 22rpx; }
.post-info { display: flex; align-items: center; gap: 16rpx; font-size: 22rpx; }
.countdown { color: #FAAD14; }
.order-count { color: #8C8C8C; }

.loading-wrap { padding: 40rpx; text-align: center; }

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1677FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.4);
  z-index: 100;
}
.fab-icon { color: #FFFFFF; font-size: 56rpx; font-weight: 300; margin-top: -4rpx; }

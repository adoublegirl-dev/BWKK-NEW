.page-create { padding-bottom: 140rpx; }
.label { display: block; font-size: 28rpx; margin-bottom: 16rpx; }
.label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.location-picker { padding: 20rpx; background: #F5F5F5; border-radius: 12rpx; }
.char-count { display: block; text-align: right; font-size: 22rpx; margin-top: 8rpx; }
.time-row { display: flex; gap: 24rpx; }
.time-value { padding: 16rpx 24rpx; background: #F5F5F5; border-radius: 12rpx; flex: 1; text-align: center; }
.submit-area { padding: 24rpx; background: #FFF; position: fixed; bottom: 0; left: 0; right: 0; }

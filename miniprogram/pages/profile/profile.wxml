<view class="page-profile">
  <view class="profile-header">
    <image class="profile-avatar" src="{{userInfo.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
    <text class="profile-name text-bold">{{userInfo.nickname || '点击登录'}}</text>
  </view>

  <view class="card points-card">
    <view class="points-main">
      <text class="points-value text-primary">{{availablePoints}}</text>
      <text class="points-label text-placeholder">可用积分</text>
    </view>
    <view class="points-frozen">
      <text class="text-placeholder">冻结: {{frozenPoints}}</text>
    </view>
    <view class="points-detail" bindtap="onGoPoints">
      <text class="text-primary" style="font-size:24rpx">查看明细 ></text>
    </view>
  </view>

  <view class="card credit-card">
    <view class="credit-item">
      <text class="credit-label">发单信用分</text>
      <text class="credit-value {{posterCredit >= 80 ? 'text-success' : 'text-danger'}}">{{posterCredit}}</text>
    </view>
    <view class="credit-divider"></view>
    <view class="credit-item">
      <text class="credit-label">接单信用分</text>
      <text class="credit-value {{doerCredit >= 80 ? 'text-success' : 'text-danger'}}">{{doerCredit}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{creditStatus !== 'normal'}}">
    <view class="flex items-center">
      <text class="text-danger text-bold">账户已冻结</text>
      <text class="text-secondary ml-sm">解封倒计时: {{frozenUntil}}</text>
    </view>
  </view>

  <view class="native-cell-group">
    <view class="native-cell" bindtap="onGoMyPosts"><text class="cell-title">我的帖子</text><text class="cell-arrow">></text></view>
    <view class="native-cell" bindtap="onGoMyOrders"><text class="cell-title">我的接单</text><text class="cell-arrow">></text></view>
    <view class="native-cell" bindtap="onGoPoints"><text class="cell-title">积分明细</text><text class="cell-arrow">></text></view>
    <view class="native-cell" bindtap="onGoCredit"><text class="cell-title">信用记录</text><text class="cell-arrow">></text></view>
  </view>
</view>

// This is your Prisma schema file,
// learn more about it in the screenshots: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== 用户表 ==========
model User {
  id           String   @id @default(cuid())
  openid       String?  @unique  // 微信openid，可为空（纯手机号登录用户）
  unionid      String?  @unique // 微信unionid，可选
  nickname     String?
  avatarUrl    String?
  city         String?

  // 邮箱登录相关
  email        String?  @unique // 邮箱
  emailVerified Boolean  @default(false) // 邮箱是否已验证
  password     String?  // 密码（可选，用于邮箱登录用户）

  // 信用分
  posterCredit  Int      @default(100)       // 发单信用分
  doerCredit    Int      @default(100)       // 接单信用分
  creditStatus  String   @default("normal")  // normal | frozen | cooldown
  frozenUntil   DateTime?

  // 积分（MVP）
  totalPoints   Int      @default(100)       // 累计获得积分
  frozenPoints  Int      @default(0)         // 冻结中的积分
  // 可用积分 = totalPoints - frozenPoints

  // 商家角色
  role           String  @default("normal")  // normal | merchant
  merchantName   String? // 商家名称（角色为merchant时必填）
  merchantDesc   String? // 商家描述
  merchantContact String? // 商家联系方式

  // 关联
  posts         Post[]
  orders        Order[]
  transactions  Transaction[]
  creditRecords CreditRecord[]
  voucherBatches VoucherBatch[]
  voucherCodes  VoucherCode[]
  exchangeRecords ExchangeRecord[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([city])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ========== 帖子表 ==========
model Post {
  id              String   @id @default(cuid())
  userId          String
  title           String   @default("帮我看看")
  description     String
  locationName    String?
  address         String?
  latitude        Float?
  longitude       Float?
  rewardAmount    Int      @default(0)        // 悬赏积分（Decimal预留，MVP用Int）
  compensateRate  Int      @default(0)        // 未选中补偿比例 0-10%
  deadline        DateTime                   // 截止时间
  status          String   @default("active") // active | completed | expired | cancelled
  orderCount              Int      @default(0)        // 接单人数
  lastViewedSubmissionsAt DateTime?                    // 发单人上次查看提交列表的时间

  // 商家帖子字段
  postType        String   @default("normal") // normal | merchant
  selectionMode   String?  // manual | random | first_n（商家帖子专用）
  selectionCount  Int      @default(1)        // 选中数量
  rewardType      String   @default("points") // points | voucher
  voucherBatchId  String?  @unique // 代金券批次关联
  autoSelectedAt  DateTime? // 自动选中执行时间

  // 关联
  user            User     @relation(fields: [userId], references: [id])
  orders          Order[]
  voucherBatch    VoucherBatch? @relation(fields: [voucherBatchId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([postType])
  @@map("posts")
}

// ========== 接单/订单表 ==========
model Order {
  id              String   @id @default(cuid())
  postId          String
  userId          String                        // 接单人
  status          String   @default("accepted") // accepted | submitted | selected | rejected | expired
  description     String?                       // 提交的文字描述
  images          String?                       // 提交的图片URL，JSON数组字符串

  // 关联
  post            Post     @relation(fields: [postId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  submittedAt     DateTime?
  selectedAt      DateTime?                     // 被选中时间（结算时间）
  lastViewedAt    DateTime?                     // 接单人上次查看此订单的时间

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([postId, userId])                    // 同一用户对同一帖子只能接一次
  @@index([userId])
  @@index([postId])
  @@index([status])
  @@map("orders")
}

// ========== 统一交易记录表 ==========
model Transaction {
  id              String   @id @default(cuid())
  userId          String                        // 交易所属用户
  type            String                        // freeze | unfreeze | earn | spend | refund | compensate
  amount          Int                            // 交易金额（正数）
  beforeBalance   Int                            // 交易前余额
  afterBalance    Int                            // 交易后余额
  paymentMode     String   @default("points")   // points | wechat（预留）
  relatedPostId   String?                       // 关联帖子
  relatedOrderId  String?                       // 关联订单
  description     String?                       // 交易描述

  // 关联
  user            User     @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

// ========== 信用分变动记录表 ==========
model CreditRecord {
  id              String   @id @default(cuid())
  userId          String
  type            String                        // poster | doer（发单信用/接单信用）
  change          Int                            // 变动值（负数为扣分）
  beforeScore     Int                            // 变动前分数
  afterScore      Int                            // 变动后分数
  reason          String                        // 变动原因
  relatedPostId   String?

  // 关联
  user            User     @relation(fields: [userId], references: [id])

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@map("credit_records")
}

// ========== 兑换商城商品表 ==========
model ShopProduct {
  id              String   @id @default(cuid())
  name            String
  description     String?
  images          String?  // JSON数组，多图URL
  categoryId      String?  // 分类ID
  pointsPrice     Int      // 所需积分
  stock           Int      @default(0)           // 库存
  exchangedCount  Int      @default(0)           // 已兑换数量
  remainingCount  Int      @default(0)           // 剩余数量
  status          String   @default("draft")     // draft | active | soldout | disabled
  validFrom       DateTime? // 可兑换开始日期
  validUntil      DateTime? // 可兑换结束日期
  province        String?  // 省
  city            String?  // 市
  district        String?  // 区

  // 关联
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  exchangeRecords ExchangeRecord[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@map("shop_products")
}

// ========== 管理员表 ==========
model AdminUser {
  id            String   @id @default(cuid())
  username      String   @unique              // 登录用户名
  password      String                        // bcrypt哈希密码
  role          String   @default("admin")    // super_admin | admin
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          AdminLog[]
  pointsAdjustmentLogs PointsAdjustmentLog[]

  @@map("admin_users")
}

// ========== 管理员操作日志表 ==========
model AdminLog {
  id            String   @id @default(cuid())
  adminId       String
  action        String                        // 操作类型：login/edit_user/edit_post/delete_post/adjust_points/adjust_credit 等
  targetType    String?                       // 目标类型：user/post/order
  targetId      String?                       // 目标ID
  detail        String?                       // 变更详情（JSON字符串）
  createdAt     DateTime @default(now())

  admin         AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("admin_logs")
}

// ========== 验证码表（邮箱） ==========
model VerificationCode {
  id          String   @id @default(cuid())
  email       String   // 邮箱
  code        String   // 验证码
  type        String   @default("login") // login | bind | reset
  used        Boolean  @default(false)   // 是否已使用
  expiresAt   DateTime // 过期时间

  createdAt   DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
  @@map("verification_codes")
}

// ========== 商品分类表（3级树形结构） ==========
model ProductCategory {
  id          String   @id @default(cuid())
  name        String   // 分类名称
  parentId    String?  // 父分类ID，null为顶级
  level       Int      @default(1)        // 1/2/3级
  sortOrder   Int      @default(0)        // 排序序号
  status      String   @default("active") // active | disabled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 自关联
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")

  // 关联商品
  products    ShopProduct[]

  @@index([parentId])
  @@index([level])
  @@index([status])
  @@map("product_categories")
}

// ========== 代金券批次表 ==========
model VoucherBatch {
  id                String   @id @default(cuid())
  merchantId        String   // 商家用户ID
  name              String   // 批次名称
  description       String?  // 批次描述
  faceValue         Int      // 面值（积分，10积分=1代金券）
  pointsPerVoucher  Int      // 每张代金券积分成本
  totalQuantity     Int      // 总数量
  distributedQty    Int      @default(0) // 已分发数量
  remainingQty      Int      // 剩余可分数量
  validDays         Int      // 有效天数（从分发时起算）
  status            String   @default("active") // active | disabled | expired
  postId            String?  // 关联帖子ID（通过Post的voucherBatchId反向关联）

  // 关联
  merchant          User     @relation(fields: [merchantId], references: [id])
  codes             VoucherCode[]
  post              Post?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([merchantId])
  @@index([status])
  @@map("voucher_batches")
}

// ========== 代金券实例表 ==========
model VoucherCode {
  id                    String   @id @default(cuid())
  batchId               String   // 所属批次ID
  userId                String?  // 持有用户ID（未分发时为null）
  redeemCode            String   @unique // 16位加密随机兑换码
  status                String   @default("unused") // unused | used | expired
  faceValue             Int      // 面值
  validFrom             DateTime? // 有效期开始
  validUntil            DateTime? // 有效期结束
  sourceType            String   @default("merchant_post") // merchant_post | shop_exchange
  redeemedAt            DateTime? // 核销时间
  redeemedByMerchantId  String?  // 核销商家ID

  // 关联
  batch                 VoucherBatch @relation(fields: [batchId], references: [id])
  user                  User?   @relation(fields: [userId], references: [id])
  exchangeRecord        ExchangeRecord?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([batchId])
  @@index([userId])
  @@index([status])
  @@index([redeemedByMerchantId])
  @@map("voucher_codes")
}

// ========== 统一兑换记录表 ==========
model ExchangeRecord {
  id              String   @id @default(cuid())
  userId          String   // 兑换用户ID
  type            String   // shop_product | voucher
  pointsCost      Int      // 消耗积分
  productId       String?  // 商品ID（type=shop_product时有值）
  productName     String?  // 商品名称（冗余）
  productImage    String?  // 商品图片（冗余）
  voucherCodeId   String?  @unique // 代金券实例ID（type=voucher时有值）
  redeemCode      String?  // 兑换码（冗余）
  faceValue       Int?     // 代金券面值
  status          String   @default("valid") // valid | used | expired | refunded
  validFrom       DateTime? // 有效期开始
  validUntil      DateTime? // 有效期结束
  redeemedAt      DateTime? // 核销时间
  redeemedBy      String?  // 核销人（商家ID）

  // 关联
  user            User        @relation(fields: [userId], references: [id])
  product         ShopProduct? @relation(fields: [productId], references: [id])
  voucherCode     VoucherCode? @relation(fields: [voucherCodeId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("exchange_records")
}

// ========== 积分调整日志表 ==========
model PointsAdjustmentLog {
  id              String   @id @default(cuid())
  adminId         String   // 操作管理员ID
  targetUserId    String?  // 目标用户ID（全量调整时为null）
  targetType      String   @default("single") // single | all
  amount          Int      // 调整数量（正数为增加，负数为减少）
  reason          String   // 调整原因
  beforeBalance   Int?     // 调整前余额（全量调整时为null）
  afterBalance    Int?     // 调整后余额（全量调整时为null）

  // 关联
  admin           AdminUser @relation(fields: [adminId], references: [id])

  createdAt       DateTime @default(now())

  @@index([adminId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("points_adjustment_logs")
}
